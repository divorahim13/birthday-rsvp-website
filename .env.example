# Required in production for the /admin password gate.
ADMIN_PASSWORD=

# Required in production for RSVP persistence.
# Any Postgres-compatible URL is supported. Neon/Vercel Postgres/Supabase Postgres work well.
DATABASE_URL=

# Optional deployment/notification automation variables.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VERCEL_TOKEN=
GITHUB_TOKEN=
